# Runtime Environment (development, production, or test)
NODE_ENV=

# The port the backend server binds to
PORT=

# PostgreSQL database connection string
DATABASE_URL=

# Cryptographic secret for signing short-lived access tokens
JWT_ACCESS_SECRET=

# Cryptographic secret for signing long-lived refresh tokens
JWT_REFRESH_SECRET=

# Expiration strings for tokens (e.g., 15m, 7d)
JWT_ACCESS_EXPIRES_IN=
JWT_REFRESH_EXPIRES_IN=

# The accepted fully-qualified domain name of the frontend app (for CORS and Cookies)
CORS_ORIGIN=

# The public URL of the frontend app (used for email links, password resets, etc.)
FRONTEND_URL=

# Google OAuth Configuration (Required for Social Login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# SMTP Email Configuration (Optional - set if you want system emails)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Set to true to enable SMS providers
ENABLE_SMS=
